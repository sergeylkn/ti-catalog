# Environment variables for Railway deployment
# Copy to Railway dashboard or create .env.railway

# ===== DATABASE =====
# Set automatically by Railway PostgreSQL plugin, but you can override:
# DATABASE_URL=postgresql://user:password@host:port/database

# ===== CLOUDFLARE R2 =====
# Get from Cloudflare dashboard -> R2 -> Create API token
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_R2_ACCESS_KEY_ID=your_access_key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your_secret_key
CLOUDFLARE_R2_BUCKET=product-pdfs
CLOUDFLARE_R2_PUBLIC_URL=https://pub-ada201ec5fb84401a3b36b7b21e6ed0f.r2.dev

# ===== OPENAI =====
# Get from openai.com/api/keys
OPENAI_API_KEY=sk-...
LLM_PROVIDER=openai
LLM_MODEL=gpt-3.5-turbo

# ===== APPLICATION =====
PYTHONUNBUFFERED=1
ENVIRONMENT=production
DEBUG=False

# ===== CORS =====
ALLOWED_ORIGINS=https://yourfrontend.vercel.app,http://localhost:3000

# ===== FEATURES =====
ENABLE_RAG=true
ENABLE_EMBEDDINGS=true
MAX_PDF_PAGES=10
EMBEDDING_MODEL=all-MiniLM-L6-v2
